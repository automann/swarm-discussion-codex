#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
BIN="$REPO_ROOT/.ai/harness/tools/local-repo-harness/node_modules/.bin/local-repo-harness"
if [[ ! -x "$BIN" ]]; then
  echo "local-repo-harness project runtime is missing; run: bunx --bun local-repo-harness@latest bootstrap --repo \"$REPO_ROOT\"" >&2
  exit 127
fi
exec "$BIN" "$@"
